{
  "name": "whatsapp-gym-agent",
  "version": "0.1.0",
  "private": true,
  "description": "AI agent that replies to WhatsApp messages for Elysium Gym (Luxembourg).",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "chat": "tsx src/chat.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "openai": "^4.73.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
