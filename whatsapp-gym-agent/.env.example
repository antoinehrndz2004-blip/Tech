# --- OpenAI API ---
OPENAI_API_KEY=sk-...

# --- WhatsApp Cloud API (Meta) ---
# From https://developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAA...
# App secret from Meta app dashboard → Settings → Basic (used to verify webhook signatures)
WHATSAPP_APP_SECRET=abcdef0123456789
# Any random string you choose — must match the one you paste in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=a-long-random-string-you-pick

# --- Handoff ---
# Phone number (E.164, digits only, no +) that receives lead + escalation notifications
STAFF_NOTIFY_NUMBER=352621234567

# --- Server ---
PORT=3000
# Path where the SQLite file lives
DATABASE_PATH=./data/agent.db
